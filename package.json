{
  "name": "snowcrystal",
  "version": "0.1.1",
  "description": "Visualize snow crystal morphology (Nakaya diagram + Global Classification of 121 types) as Three.js geometry. A morphological visualization, not a physical growth model.",
  "type": "module",
  "license": "MIT",
  "author": "Shotaro Kamimura (SnowNotes)",
  "keywords": [
    "three",
    "threejs",
    "snow",
    "crystal",
    "snowflake",
    "nakaya-diagram",
    "visualization",
    "geometry"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shotaro-Kamimura/snowcrystal.git"
  },
  "homepage": "https://github.com/Shotaro-Kamimura/snowcrystal#readme",
  "bugs": {
    "url": "https://github.com/Shotaro-Kamimura/snowcrystal/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.43.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.160.0",
    "three": "^0.160.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^3.2.6"
  }
}
